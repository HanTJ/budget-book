# ==============================================================
# Budget Book — 닷홈 배포용 .env 템플릿
# FTP 로 public_html/.env 로 업로드한 뒤 값을 채우세요.
# ==============================================================

# ---- DB (닷홈 관리패널 > MySQL 에서 확인) ----
DB_HOST=localhost
# DB_PORT 는 생략한다. 닷홈은 host=localhost 에 대해 unix socket 경로로 접속하므로
# port 를 명시하면 오히려 TCP 로 붙으려다 연결이 실패한다. 외부 호스트/특수 포트를
# 쓰는 환경에서만 아래 줄의 주석을 해제하고 값을 넣을 것.
# DB_PORT=3306
DB_DATABASE=samdogs
DB_USERNAME=samdogs
DB_PASSWORD=__DB_PASSWORD_HERE__

# ---- App ----
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Seoul
APP_URL=https://samdogs.dothome.co.kr

# ---- CORS (same-origin 배포이므로 미들웨어 미등록) ----
CORS_ALLOWED_ORIGIN=same-origin

# ---- JWT (openssl rand -base64 48 로 생성한 48자 이상 랜덤 문자열 권장) ----
JWT_SECRET=__GENERATE_48_CHAR_RANDOM_STRING__
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
