JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8080/api

# Initial admin (bootstrap account — promoted to ADMIN/ACTIVE by `make admin-seed`)
