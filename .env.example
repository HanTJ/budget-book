# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=budget_book
MYSQL_TEST_DATABASE=budget_book_test
MYSQL_USER=budget
MYSQL_PASSWORD=budget
MYSQL_HOST=mysql
MYSQL_PORT=3306

# App
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Seoul
APP_URL=http://localhost:8080

# CORS
# - 로컬 개발(프론트 3000, 백엔드 8080)처럼 origin 이 다를 때는 프론트 origin 을 지정
# - 닷홈처럼 동일 도메인으로 배포할 때는 빈값 또는 'same-origin' 으로 두어 미들웨어 자체를 미등록
CORS_ALLOWED_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET=change-me-change-me-change-me-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8080/api

# Initial admin (bootstrap account — promoted to ADMIN/ACTIVE by `make admin-seed`)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-please
INITIAL_ADMIN_NAME=Administrator
